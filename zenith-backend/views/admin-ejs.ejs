<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/ejs.css" />
  </head>
  <body>
    <main class="shell">
      <section class="hero">
        <p class="eyebrow">Admin Dashboard (EJS)</p>
        <h1>Welcome, <%= adminName %></h1>
        <p>This page demonstrates EJS loops, conditionals, and dynamic backend data.</p>
      </section>

      <% if (showWarning) { %>
        <section class="panel warning-box">
          <strong>MongoDB is currently offline.</strong>
          <p><%= database.message %></p>
        </section>
      <% } %>

      <section class="grid">
        <% adminCards.forEach(function(card) { %>
          <article class="card">
            <p class="label"><%= card.title %></p>
            <p><%= card.details %></p>
          </article>
        <% }) %>
      </section>
    </main>
  </body>
</html>
